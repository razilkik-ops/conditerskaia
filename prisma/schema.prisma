generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  CAKE
  DESSERT
}

enum OrderStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  STANDARD
  CUSTOM
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MOCK
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  phone        String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  orders Order[]
}

model Product {
  id          String      @id @default(cuid())
  type        ProductType
  name        String
  slug        String      @unique
  description String
  price       Int
  imageUrl    String
  category    String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  cakeOptions CakeOption[]
  inventory   Inventory[]
  orderItems  OrderItem[]
}

model CakeOption {
  id         String @id @default(cuid())
  productId  String
  weight     String
  filling    String
  decorStyle String
  extraPrice Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inventory {
  id                String   @id @default(cuid())
  productId         String
  date              DateTime @db.Date
  quantityAvailable Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([date])
}

model Order {
  id              String          @id @default(cuid())
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  status          OrderStatus     @default(NEW)
  orderType       OrderType       @default(STANDARD)
  fulfillmentType FulfillmentType
  deliveryAddress String?
  pickupDateTime  DateTime
  comment         String?
  totalAmount     Int
  paymentStatus   PaymentStatus   @default(PENDING)
  createdAt       DateTime        @default(now())

  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items   OrderItem[]
  payment Payment?

  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  selectedDate    DateTime @db.Date
  selectedOptions Json?
  unitPrice       Int
  totalPrice      Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model UnavailableDate {
  id     String   @id @default(cuid())
  date   DateTime @unique @db.Date
  reason String
}

model Payment {
  id         String          @id @default(cuid())
  orderId    String          @unique
  provider   PaymentProvider @default(MOCK)
  status     PaymentStatus   @default(PENDING)
  amount     Int
  paymentUrl String
  createdAt  DateTime        @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
